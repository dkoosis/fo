{
  "threshold": 3,
  "minLines": 12,
  "maxLines": 1000,
  "minTokens": 100,
  "maxSize": "100kb",
  "reporters": ["console"],
  "mode": "mild",
  "ignoreCase": false,
  "gitignore": true,
  "ignore": [
    "**/*_test.go",
    "**/testdata/**",
    "**/.worktrees/**",
    "**/*.pb.go",
    "**/*.gen.go",
    "**/vendor/**",
    "**/node_modules/**",
    ".claude/**",
    ".sandbox/**",
    "bin/**",
    "docs/**"
  ],
  "format": ["go", "yaml", "json", "markdown"],
  "absolute": false,
  "skipLocal": false
}
