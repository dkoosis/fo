#!/bin/bash
# Pre-commit hook to:
# 1. Sync GitHub issues to docs/issues.json
# 2. Block temporary/backup file naming patterns
# 3. Enforce documentation governance

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

# ============================================================================
# Sync GitHub Issues to docs/issues.json
# ============================================================================

ISSUES_FILE="docs/issues.json"

if command -v gh &> /dev/null; then
    echo -e "${BLUE}Syncing open GitHub issues...${NC}"

    # Fetch open issues with full data
    if gh issue list --state open --json number,title,body,state,labels,assignees,createdAt,updatedAt,closedAt > "$ISSUES_FILE.tmp" 2>/dev/null; then
        # Check if content changed
        if ! cmp -s "$ISSUES_FILE.tmp" "$ISSUES_FILE" 2>/dev/null; then
            mv "$ISSUES_FILE.tmp" "$ISSUES_FILE"
            git add "$ISSUES_FILE"
            ISSUE_COUNT=$(jq length "$ISSUES_FILE" 2>/dev/null || echo "?")
            echo -e "${GREEN}✓ Synced $ISSUE_COUNT open issues to $ISSUES_FILE${NC}"
        else
            rm -f "$ISSUES_FILE.tmp"
            echo -e "${GREEN}✓ Issues unchanged${NC}"
        fi
    else
        rm -f "$ISSUES_FILE.tmp"
        echo -e "${YELLOW}⚠ Could not fetch issues (gh auth or network issue)${NC}"
    fi
else
    echo -e "${YELLOW}⚠ gh CLI not found, skipping issue sync${NC}"
fi

# ============================================================================
# Block Temporary/Backup File Patterns
# ============================================================================

STAGED_FILES=$(git diff --cached --name-only --diff-filter=A || true)
BLOCKED_TEMP_FILES=()

if [ -n "$STAGED_FILES" ]; then
    while IFS= read -r file; do
        filename=$(basename "$file")

        # Check for temporary/backup naming patterns
        if [[ "$filename" =~ \.bak || "$filename" =~ \.bac || \
              "$filename" =~ fixed || "$filename" =~ final || \
              "$filename" =~ enhanced || "$filename" =~ \.backup || \
              "$filename" =~ v[0-9] ]]; then
            BLOCKED_TEMP_FILES+=("$file")
        fi
    done <<< "$STAGED_FILES"
fi

if [ ${#BLOCKED_TEMP_FILES[@]} -gt 0 ]; then
    echo ""
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}❌ COMMIT BLOCKED - Temporary/Backup Files Detected${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${YELLOW}The following files have temporary/backup naming patterns:${NC}"
    echo ""
    for file in "${BLOCKED_TEMP_FILES[@]}"; do
        echo -e "  ${RED}✗${NC} $file"
    done
    echo ""
    echo -e "${BLUE}Blocked patterns:${NC}"
    echo -e "  ${RED}✗${NC} *.bak* (e.g., file.bak, file.bak1)"
    echo -e "  ${RED}✗${NC} *.bac* (e.g., file.backup)"
    echo -e "  ${RED}✗${NC} *fixed* (e.g., file-fixed.go)"
    echo -e "  ${RED}✗${NC} *final* (e.g., final-version.md)"
    echo -e "  ${RED}✗${NC} *enhanced* (e.g., enhanced-output.txt)"
    echo -e "  ${RED}✗${NC} *v[0-9]* (e.g., script-v2.sh, file-v10.go)"
    echo ""
    echo -e "${YELLOW}Action required:${NC}"
    echo -e "  1. Remove these files from staging: ${BLUE}git restore --staged <file>${NC}"
    echo -e "  2. Delete the temporary files: ${BLUE}rm <file>${NC}"
    echo -e "  3. Commit your actual changes"
    echo ""
    echo -e "${RED}To override (not recommended):${NC}"
    echo -e "  git commit --no-verify"
    echo ""
    exit 1
fi

# ============================================================================
# Documentation Governance Check
# ============================================================================

# Get list of staged .md files (new files only)
STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=A | grep '\.md$' || true)

if [ -z "$STAGED_MD_FILES" ]; then
    exit 0
fi

echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${YELLOW}⚠️  Documentation Governance Check${NC}"
echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo -e "${RED}You are attempting to add new markdown file(s):${NC}"
echo ""

BLOCKED_FILES=()
WARNED_FILES=()

while IFS= read -r file; do
    # Check against allowed patterns
    if [[ "$file" =~ ^[^/]+/README\.md$ ]]; then
        # Module README (e.g., mageconsole/README.md)
        echo -e "  ${GREEN}✓${NC} $file"
        continue
    elif [[ "$file" =~ ^internal/[^/]+/README\.md$ ]]; then
        # Internal module README
        echo -e "  ${GREEN}✓${NC} $file"
        continue
    elif [[ "$file" =~ ^cmd/README\.md$ ]]; then
        # Binary documentation
        echo -e "  ${GREEN}✓${NC} $file"
        continue
    elif [[ "$file" =~ ^docs/adr/ADR-[0-9]{3}-[a-z0-9-]+\.md$ ]]; then
        # ADRs with new naming (ADR-001, ADR-002, etc.)
        echo -e "  ${GREEN}✓${NC} $file"
        continue
    elif [[ "$file" =~ ^docs/adr/README\.md$ ]]; then
        # ADR index/template
        echo -e "  ${GREEN}✓${NC} $file"
        continue
    elif [[ "$file" =~ ^docs/(PATTERNS|MIGRATION|VISION_REVIEW|README|DOCUMENTATION_POLICY)\.md$ ]]; then
        # Core top-level docs
        echo -e "  ${GREEN}✓${NC} $file"
        continue
    elif [[ "$file" =~ ^CLAUDE\.md$ ]] || [[ "$file" =~ ^AGENTS\.md$ ]]; then
        # Claude Code / Codex project guidance
        echo -e "  ${GREEN}✓${NC} $file"
        continue
    elif [[ "$file" =~ ^README\.md$ ]] || [[ "$file" =~ ^decisions\.log$ ]]; then
        # Root README and decisions log
        echo -e "  ${GREEN}✓${NC} $file"
        continue
    elif [[ "$file" =~ ^docs/ ]]; then
        # Other docs/** files - warn but allow
        echo -e "  ${YELLOW}⚠${NC} $file"
        WARNED_FILES+=("$file")
    else
        # Everything else is blocked
        echo -e "  ${RED}✗${NC} $file"
        BLOCKED_FILES+=("$file")
    fi
done <<< "$STAGED_MD_FILES"

if [ ${#WARNED_FILES[@]} -gt 0 ]; then
    echo ""
    echo -e "${YELLOW}Files in docs/** are allowed but discouraged.${NC}"
    echo -e "${GREEN}Proceeding with commit...${NC}"
    echo ""
fi

if [ ${#BLOCKED_FILES[@]} -gt 0 ]; then
    echo ""
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}❌ COMMIT BLOCKED${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${YELLOW}Markdown files outside allowed locations violate documentation policy.${NC}"
    echo ""
    echo -e "${YELLOW}Allowed .md locations:${NC}"
    echo -e "  ${GREEN}✓${NC} [module]/README.md (e.g., mageconsole/README.md)"
    echo -e "  ${GREEN}✓${NC} internal/[module]/README.md"
    echo -e "  ${GREEN}✓${NC} cmd/README.md"
    echo -e "  ${GREEN}✓${NC} docs/adr/ADR-NNN-title.md (e.g., ADR-001-pattern-based-architecture.md)"
    echo -e "  ${GREEN}✓${NC} docs/{PATTERNS,MIGRATION,VISION_REVIEW,README,DOCUMENTATION_POLICY}.md"
    echo -e "  ${GREEN}✓${NC} README.md, decisions.log (root)"
    echo -e "  ${YELLOW}⚠${NC} docs/** (other locations allowed with warning)"
    echo ""
    echo -e "${RED}To override:${NC} git commit --no-verify"
    echo ""
    exit 1
fi

echo -e "${GREEN}✓ All new markdown files follow documentation policy${NC}"
echo ""
exit 0

# --- BEGIN BEADS INTEGRATION v1.0.2 ---
# This section is managed by beads. Do not remove these markers.
if command -v bd >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  _bd_timeout=${BEADS_HOOK_TIMEOUT:-300}
  if command -v timeout >/dev/null 2>&1; then
    timeout "$_bd_timeout" bd hooks run pre-commit "$@"
    _bd_exit=$?
    if [ $_bd_exit -eq 124 ]; then
      echo >&2 "beads: hook 'pre-commit' timed out after ${_bd_timeout}s — continuing without beads"
      _bd_exit=0
    fi
  else
    bd hooks run pre-commit "$@"
    _bd_exit=$?
  fi
  if [ $_bd_exit -eq 3 ]; then
    echo >&2 "beads: database not initialized — skipping hook 'pre-commit'"
    _bd_exit=0
  fi
  if [ $_bd_exit -ne 0 ]; then exit $_bd_exit; fi
fi
# --- END BEADS INTEGRATION v1.0.2 ---
